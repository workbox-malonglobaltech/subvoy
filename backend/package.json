    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "googleapis": "^171.4.0",
    "helmet": "^7.1.0",
    "imapflow": "^1.3.1",
    "jsonwebtoken": "^9.0.3",
    "mailparser": "^3.9.8",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
