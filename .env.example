# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/subvoy

# ── Auth ─────────────────────────────────────────────────────────────────────
# Min 32 random chars — generate with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_string_min_32_chars

# ── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Email / SMTP ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=Subvoy <your_email@gmail.com>

# Timezone for the daily 8 AM reminder job (IANA name)
# Examples: America/New_York, Europe/London, Africa/Lagos
REMINDER_TIMEZONE=Africa/Lagos

# ── OAuth — Google & Microsoft (email import) ─────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
OAUTH_REDIRECT_BASE_URL=http://localhost:3001

# 64-char hex string for AES-256-GCM token encryption
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=generate_with_openssl_rand_hex_32

# ── Wallet ───────────────────────────────────────────────────────────────────
# Mock NGN→USD conversion rate (kobo per cent, i.e. 1 USD = 1600 NGN)
# In production this will come from a live FX provider
MOCK_NGN_USD_RATE=1600

# Auto top-up cron schedule (default: every hour)
# Standard cron format: minute hour day-of-month month day-of-week
WALLET_TOPUP_CRON=0 * * * *

# ── FX Rates ─────────────────────────────────────────────────────────────────
# Optional: API key for a live FX provider (e.g. ExchangeRate-API, Open Exchange Rates)
# Leave blank to use cached/mock rates
FX_API_KEY=

# ── Supabase Auth (single IdP for web + iOS + Android) ───────────────────────
# When SUPABASE_JWT_SECRET is set, the API ALSO accepts `Authorization: Bearer`
# Supabase access tokens (in addition to the legacy cookie session). Find it in
# Supabase: Project Settings → API → JWT Settings.
# SUPABASE_JWT_SECRET=
# Client-side (frontend/mobile .env), for supabase-js:
# VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=

# ── Auth cookie (split-origin deploys) ───────────────────────────────────────
# Default is same-origin friendly (SameSite=lax). For split origin
# (app.subvoy.com ↔ api.subvoy.com): COOKIE_SAMESITE=none, COOKIE_SECURE=true,
# COOKIE_DOMAIN=.subvoy.com  (and add CSRF tokens before using SameSite=none).
# COOKIE_SAMESITE=lax
# COOKIE_SECURE=true
# COOKIE_DOMAIN=.subvoy.com

# ── Database pool (managed Postgres) ─────────────────────────────────────────
# DB_SSL=true            # required for Supabase/Neon/etc.
# DB_SSL_STRICT=true     # verify the provider cert chain
# DB_POOL_MAX=10
# DB_STATEMENT_TIMEOUT_MS=15000

# ── Paystack (NGN wallet top-up + Africa plan billing) ───────────────────────
# Use test keys from https://dashboard.paystack.com/#/settings/developers
# sk_test_... for test mode, sk_live_... for production
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key

# ── Stripe (plan billing, rest of world) ─────────────────────────────────────
# https://dashboard.stripe.com/apikeys — billing degrades to "not configured"
# until these are set. STRIPE_WEBHOOK_SECRET is the signing secret for the
# /billing/webhook/stripe endpoint.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Frontend-only env vars (prefix VITE_ so Vite exposes them) ───────────────
# Set in frontend/.env (not this file). Needed to enable the Paystack UI button.
# VITE_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key

# ── Sentry (error monitoring) ────────────────────────────────────────────────
# Create a project at https://sentry.io and copy the DSN from Settings → SDK Setup
# Leave blank (or omit) to disable Sentry — the app works normally without it.
SENTRY_DSN=

# Frontend Sentry DSN — set in frontend/.env as VITE_SENTRY_DSN
# (Must be prefixed VITE_ so Vite exposes it to the browser bundle)
# VITE_SENTRY_DSN=https://...@sentry.io/...

# Optional: tag releases so Sentry can link errors to a specific deploy
# Typically set by CI: APP_VERSION=$(git rev-parse --short HEAD)
# APP_VERSION=

# ── Grey/Geegpay (USD virtual card issuing — P2) ─────────────────────────────
# GEEGPAY_API_KEY=...
